/* LangChain Orchestrator - Pure Responsive Horizon */
$bg-color: #000000;
$border-color: #334155;
$accent-color: #bef264;
$ai-accent: #a855f7;

Screen { background: $bg-color; color: #fff; }

#global-scroll {
    height: 100%;
    width: 100%;
}

#main-grid {
    layout: grid;
    grid-gutter: 0 0;
    height: auto;
    min-height: 100%;
    width: 100%;
}

/* RESPONSIVE CLASSES */
/* 1-Column Stack (Unified Verticality) */
.layout-1 { 
    grid-size: 1; 
    grid-columns: 1fr; 
}
.layout-1 .column { height: auto; }
.layout-1 .panel { height: 25; margin-bottom: 1; }
.layout-1 #split-area { layout: vertical; height: auto; } /* Ensure Cloud/Docker/K8s stack vertically */
.layout-1 #stack-panel { height: auto; }
.layout-1 #docker-panel { height: 40; } /* Give Docker more room when stacked */
.layout-1 #k8s-panel { height: 25; }

/* 4-Column Master Grid (Fixed Command Center) */
.layout-4 { grid-size: 4 1; grid-columns: 1fr 1fr 1fr 1fr; }
.layout-4 #col-control { column-span: 2; }
.layout-4 .column { height: 100%; }

/* CPU Grid Responsive Classes */
.cpu-1 { grid-size: 1; }
.cpu-2 { grid-size: 2; }
.cpu-4 { grid-size: 4; }

.column { height: 100%; }

.panel {
    border: round $border-color;
    border-title-align: left;
    border-title-color: $accent-color;
    border-title-style: bold;
    margin: 0;
    padding: 0;
}

/* GLOBAL SCROLLBAR THEME */
* {
    scrollbar-color: $accent-color 30%;
    scrollbar-color-active: $accent-color;
    scrollbar-color-hover: $accent-color 70%;
}

.panel DataTable { height: 1fr; scrollbar-gutter: stable; }

/* COLUMN 1: AI (40/60 Ratio in 4-col) */
#ai-chat-panel { height: 40%; border-title-color: $ai-accent; }
#ai-history { height: 1fr; background: #000; overflow-y: scroll; }
#ai-input { height: 1; border: none; background: #1e1b4b; color: $ai-accent; padding: 0 1; }
#agent-panel { height: 60%; }

/* COLUMN 2 & 3: CONTROL */
#term-panel { height: 40%; }
#term-tabs { height: 1; background: #0f172a; border-bottom: solid $border-color; }
.term-tab { width: 3; height: 1; background: #1e293b; color: #94a3b8; text-align: center; }
.term-tab.active { background: $accent-color; color: #000; text-style: bold; }
#add-term { min-width: 3; height: 1; border: none; background: #334155; color: #fff; }
#term-switcher { height: 1fr; background: #000; }
#input-area { height: 1; background: #0f172a; padding: 0 1; }
#terminal-input { height: 1; border: none; background: transparent; width: 1fr; }

#split-area { height: 60%; }
#cloud-panel { width: 1fr; }
#stack-panel { width: 1.2fr; height: 100%; }
#docker-panel { height: 1fr; }
#k8s-panel { height: 1fr; }

/* COLUMN 4: SYSTEM */
#col-system { scrollbar-size: 0 0; }
#cpu-panel { height: auto; min-height: 4; max-height: 50%; overflow-y: scroll; }
#cpu-grid { 
    layout: grid; 
    height: auto; 
    grid-gutter: 0 1;
    padding: 0;
    margin: 0;
}

#res-panel { height: auto; }
#net-panel { height: auto; }
#proc-panel { height: 1fr; } 

StatusBar { height: 1; margin: 0; padding: 0; }
.sub-title { color: $accent-color; height: 1; text-style: bold; margin-left: 1; }
.small-label { color: #64748b; height: 1; padding-left: 1; }
